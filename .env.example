# ---- VentVerse environment configuration ----
# Copy to .env (local) or set these in your host's dashboard (Render etc.).

# Port the server listens on (hosts usually set this automatically).
PORT=4000

# Secret used to sign login tokens. CHANGE THIS in production.
JWT_SECRET=change-me-to-a-long-random-string

# ---- Storage backend ----
# "sqlite" (default, zero-config) or "sheets" (Google Sheets backend).
STORAGE=sqlite

# ---- Google Sheets backend (only needed when STORAGE=sheets) ----
# The spreadsheet that holds the data (one tab per module, auto-created).
GOOGLE_SHEET_ID=1spHrpanGCIuMtHYLXvreZ6m3DavZjj0WuRNiLOjDF50

# Service-account credentials with access to the spreadsheet above.
# Paste the FULL service-account key JSON on one line, OR use
# GOOGLE_APPLICATION_CREDENTIALS to point at a key file path instead.
# Remember to share the spreadsheet (Editor) with the service-account email.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"...@...iam.gserviceaccount.com"}
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
